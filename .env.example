# =============================================
# MiniMax API 配置
# =============================================

# MiniMax API Key（从 MiniMax 开放平台获取）
MINIMAX_API_KEY={your-minimax-api-key}

# MiniMax API 基础地址（通常不需要修改）
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

#使用的模型名称
MINIMAX_MODEL_NAME=minimax-text-01

LANGSMITH_TRACING=true
LANGSMITH_API_KEY={your-langsmith-api-key}  # 从 langchain.com/langsmith 免费获取
LANGSMITH_PROJECT=smart-customer-service   # 项目名称

# =============================================
# SiliconFlow Rerank API 配置
# =============================================
# 从 https://www.siliconflow.cn 获取
SILICONFLOW_API_KEY={your-siliconflow-api-key}